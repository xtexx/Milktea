<resources>

    <declare-styleable name="MyMaterialDesign">
        <attr name="colorSurface" format="color" />
        <attr name="colorNormalReactionCounterBackground" format="color" />
        <attr name="colorSelectedReactionCounterBackground" format="color" />

        <attr name="colorBottomNavigationSelected" format="color" />
        <attr name="colorBottomNavigationNotSelect" format="color" />

        <attr name="normalIconTint" format="color" />

        <attr name="colorMessageSelf" format="color" />
        <attr name="colorMessageRecipient" format="color" />

        <attr name="colorSeparator" format="color" />

        <attr name="colorDotTabNormal" format="color" />
        <attr name="colorDotTabSelected" format="color" />

        <attr name="emojiPickerRippleColor" format="color" />
    </declare-styleable>

    <style name="ReactionTabStyle" parent="Widget.Material3.TabLayout">
        <item name="android:textColor">?android:attr/textColor</item>
    </style>
    <style name="LicensePageTheme" parent="Theme.AppCompat.Light.DarkActionBar"/>

    <style name="TabStyle" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">?attr/colorPrimary</item>
        <item name="background">?attr/colorPrimary</item>
    </style>

    <style name="TextInputLayoutStyle" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="hintTextColor">?attr/colorPrimary</item>
        <item name="colorControlActivated">?attr/colorPrimary</item>
        <item name="materialThemeOverlay">@style/ThemeOverlay.TextInputEditText</item>
    </style>

    <style name="ThemeOverlay.TextInputEditText" parent="ThemeOverlay.Material3.TextInputEditText.OutlinedBox">
        <!-- カーソルの色を変更している -->
        <item name="colorControlActivated">?attr/colorPrimary</item>

        <!-- boxStrokeColor が選択時に colorPrimary を参照するため -->
        <item name="colorPrimary">?attr/colorPrimary</item>
    </style>

    <style name="DialogStyle" parent="ThemeOverlay.Material3.Dialog">
        <item name="buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
    </style>
    <style name="NegativeButtonStyle" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@android:color/white</item>
    </style>
    <style name="PositiveButtonStyle" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColorPrimary">?attr/colorPrimary</item>
    </style>

    <style name="NotificationSnackBarTextView" parent="Widget.Material3.Snackbar">
        <item name="android:textColor">@color/colorTextColorPrimary</item>
    </style>

    <style name="BottomNavigationView4Dark" parent="Widget.Material3.BottomNavigationView">
        <item name="elevation">0dp</item>
    </style>
    <style name="TabLayout4Light" parent="Widget.Material3.TabLayout">
        <item name="elevation">4dp</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="EmojiPickerLayoutStyle">
        <item name="colorControlHighlight">?attr/emojiPickerRippleColor</item>
    </style>
</resources>
